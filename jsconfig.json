{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "preserve",
    "allowSyntheticDefaultImports": true,
    "checkJs": true,
    "strict": false,
    "types": ["vite/client"]
  },
  "include": ["src/**/*"]
}
